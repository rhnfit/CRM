PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rhn_crm?schema=public"
JWT_SECRET="replace-with-strong-secret"
JWT_EXPIRES_IN="1d"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET=""
REFRESH_TOKEN_EXPIRES_DAYS="30"
REDIS_URL="redis://localhost:6379"
WHATSAPP_VERIFY_TOKEN="set-for-meta-webhook-verify"
WHATSAPP_APP_SECRET=""
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
INCENTIVE_PERCENT="0.05"
STALE_LEAD_HOURS="24"
# Comma-separated; must include every Next.js origin you use (e.g. :3000 and :3001).
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001"

# When frontend and API are on different hosts (e.g. Vercel + Railway), use "none" so cookies
# and Socket.IO work cross-site. Requires HTTPS (NODE_ENV=production). Local dev: omit or "lax".
# COOKIE_SAME_SITE="none"

# S3 call recordings
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET=""

# Email alerts (SMTP — leave blank to disable)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
ALERT_FROM="crm@rhn.local"
ALERT_TO="director@rhn.local"
